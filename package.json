{
  "name": "@malaclyde/context7-cache-oc",
  "version": "0.1.3",
  "description": "OpenCode plugin — caches Context7 documentation lookups in SQLite + embeddings + FTS5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Malaclyde/context7-cache"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir=dist --target=bun --external=@opencode-ai/plugin --external=@xenova/transformers",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.14.48"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.2"
  }
}
